# Database container credentials (safe local defaults)
POSTGRES_DB=lost_found
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Backend settings
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/lost_found
CORS_ORIGINS=http://localhost,http://localhost:5173,http://127.0.0.1,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=true
APP_ENV=dev
EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_WARMUP_ON_STARTUP=true
SEMANTIC_MATCHING_ENABLED=true
SEMANTIC_STRICT_MODE=false
MEDIA_TMP_TTL_HOURS=24
MEDIA_CLEANUP_INTERVAL_MINUTES=60
CREATE_RATE_LIMIT_WINDOW_MINUTES=10
CREATE_RATE_LIMIT_MAX_ITEMS=5
CREATE_RATE_LIMIT_MAX_ITEMS_ANON=3
UPLOAD_RATE_LIMIT_WINDOW_MINUTES=10
UPLOAD_RATE_LIMIT_MAX=12
UPLOAD_RATE_LIMIT_MAX_ANON=5
LINK_CODE_RATE_LIMIT_WINDOW_MINUTES=30
LINK_CODE_RATE_LIMIT_MAX=6
LINK_CONFIRM_RATE_LIMIT_WINDOW_MINUTES=20
LINK_CONFIRM_RATE_LIMIT_MAX=10
FLAG_RATE_LIMIT_WINDOW_MINUTES=30
FLAG_RATE_LIMIT_MAX=8
FLAG_RATE_LIMIT_MAX_ANON=5
CLAIM_RATE_LIMIT_WINDOW_MINUTES=30
CLAIM_RATE_LIMIT_MAX=8
CLAIM_RATE_LIMIT_MAX_ANON=2
SMART_SEARCH_RATE_LIMIT_WINDOW_MINUTES=10
SMART_SEARCH_RATE_LIMIT_MAX=60
CATEGORY_SUGGEST_RATE_LIMIT_WINDOW_MINUTES=10
CATEGORY_SUGGEST_RATE_LIMIT_MAX=60
ADMIN_AUDIT_RATE_LIMIT_WINDOW_MINUTES=5
ADMIN_AUDIT_RATE_LIMIT_MAX=120
ANTI_ABUSE_EVENT_RETENTION_DAYS=30

# Telegram-linked admin/moderator authorization
# Preferred secure method: allowlist immutable Telegram numeric IDs.
ADMIN_TELEGRAM_USER_IDS=
# Bootstrap convenience: allowlist Telegram usernames for first login.
# Use usernames without "@", comma-separated if multiple.
ADMIN_TELEGRAM_USERNAMES=Leo0742
# Explicitly enable username bootstrap. Keep false unless you are doing first-time bootstrap.
ADMIN_USERNAME_BOOTSTRAP_ENABLED=true
# Optional legacy fallback for local/dev only. Keep false in normal use.
ALLOW_ADMIN_SECRET_FALLBACK=false

# Frontend build-time API base URL
VITE_API_BASE_URL=/api

# Telegram bot settings
# Keep this secret out of git. Bot service is optional and started with --profile bot.
TELEGRAM_BOT_TOKEN=replace_me
API_BASE_URL=http://backend:8000/api
INTERNAL_API_TOKEN=change-me-internal-token
# In non-dev environments, keep strict check enabled and set INTERNAL_API_TOKEN
# to a non-default secret value.
STRICT_INTERNAL_TOKEN=true
